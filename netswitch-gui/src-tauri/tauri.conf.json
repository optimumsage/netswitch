{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "netswitch-gui",
  "version": "0.1.0",
  "identifier": "com.optimumsage.netswitch-gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Netswitch",
        "width": 500,
        "height": 650,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/optimumsage/netswitch/releases/latest/download/latest.json"
      ],
      "pubkey": "RWThRH2AntlWhVZU3qOWybr5jy0VQNZCWq7LE2ytazgIKTOJB/CmnAqk"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bin/*",
      "service/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
